# ============================================================
# ERP Empresarial — Variáveis de Ambiente
# Copie para .env e ajuste os valores
# ============================================================

# ── App ──
APP_ENV=development
DEBUG=true

# ── Database ──
DATABASE_URL=postgresql+asyncpg://erp:erp_dev_secret@localhost:5432/erp_empresarial
DATABASE_URL_SYNC=postgresql+psycopg2://erp:erp_dev_secret@localhost:5432/erp_empresarial

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT RS256 ──
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SMTP ──
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ERP Empresarial
SMTP_FROM_EMAIL=
APP_URL=http://localhost
